---
const { repo } = Astro.props;
---

<section id="install">
	<h2>Install</h2>
	<p>
		fossil builds from source with <a target="_blank" href="https://rustup.rs"
			>Rust</a
		>.
	</p>

	<div class="tabs" role="tablist">
		<button class="tab active" data-os="mac" type="button">macOS</button>
		<button class="tab" data-os="linux" type="button">Linux</button>
		<button class="tab" data-os="win" type="button">Windows</button>
	</div>

	<div class="panels">
		<button class="clipboard" type="button" aria-label="Copy install command">
			<span class="clipboard-icon" aria-hidden="true">
				<svg
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="currentColor"
					width="16"
					height="16"
				>
					<path
						fill-rule="evenodd"
						d="M17.663 3.118c.225.015.45.032.673.05C19.876 3.298 21 4.604 21 6.109v9.642a3 3 0 0 1-3 3V16.5c0-5.922-4.576-10.775-10.384-11.217.324-1.132 1.3-2.01 2.548-2.114.224-.019.448-.036.673-.051A3 3 0 0 1 13.5 1.5H15a3 3 0 0 1 2.663 1.618ZM12 4.5A1.5 1.5 0 0 1 13.5 3H15a1.5 1.5 0 0 1 1.5 1.5H12Z"
						clip-rule="evenodd"></path>
					<path
						d="M3 8.625c0-1.036.84-1.875 1.875-1.875h.375A3.75 3.75 0 0 1 9 10.5v1.875c0 1.036.84 1.875 1.875 1.875h1.875A3.75 3.75 0 0 1 16.5 18v2.625c0 1.035-.84 1.875-1.875 1.875h-9.75A1.875 1.875 0 0 1 3 20.625v-12Z"
					></path>
					<path
						d="M10.5 10.5a5.23 5.23 0 0 0-1.279-3.434 9.768 9.768 0 0 1 6.963 6.963 5.23 5.23 0 0 0-3.434-1.279h-1.875a.375.375 0 0 1-.375-.375V10.5Z"
					></path>
				</svg>
			</span>
		</button>

		<pre
			class="panel active"
			data-os="mac"><code># install Rust (skip if you already have it)
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh

# install fossil
cargo install --git {repo}

fossil help</code></pre>

		<pre
			class="panel"
			data-os="linux"><code># install Rust (skip if you already have it)
curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh

# install fossil
cargo install --git {repo}

fossil help</code></pre>

		<pre
			class="panel"
			data-os="win"><code># install Rust from https://rustup.rs (run rustup-init.exe), then in PowerShell:
cargo install --git {repo}

fossil help</code></pre>
	</div>
</section>

<script>
	const tabs = document.querySelectorAll<HTMLButtonElement>("#install .tab");
	const panels = document.querySelectorAll<HTMLElement>("#install .panel");
	const wrap = document.querySelector<HTMLElement>("#install .panels")!;
	const copy = document.querySelector<HTMLButtonElement>(
		"#install .clipboard",
	)!;
	const copyIcon = copy.querySelector<HTMLElement>(".clipboard-icon")!;

	const normalIcon = copyIcon.innerHTML;

	const copiedIcon = `
		<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
			fill="currentColor" width="16" height="16">
			<path fill-rule="evenodd"
				d="M7.502 6h7.128A3.375 3.375 0 0 1 18 9.375v9.375a3 3 0 0 0 3-3V6.108c0-1.505-1.125-2.811-2.664-2.94a48.972 48.972 0 0 0-.673-.05A3 3 0 0 0 15 1.5h-1.5a3 3 0 0 0-2.663 1.618c-.225.015-.45.032-.673.05C8.662 3.295 7.554 4.542 7.502 6ZM13.5 3A1.5 1.5 0 0 0 12 4.5h4.5A1.5 1.5 0 0 0 15 3h-1.5Z"
				clip-rule="evenodd" />
			<path fill-rule="evenodd"
				d="M3 9.375C3 8.339 3.84 7.5 4.875 7.5h9.75c1.036 0 1.875.84 1.875 1.875v11.25c0 1.035-.84 1.875-1.875 1.875h-9.75A1.875 1.875 0 0 1 3 20.625V9.375Zm9.586 4.594a.75.75 0 0 0-1.172-.938l-2.476 3.096-.908-.907a.75.75 0 0 0-1.06 1.06l1.5 1.5a.75.75 0 0 0 1.116-.062l3-3.75Z"
				clip-rule="evenodd" />
		</svg>
	`;

	let copiedTimer: number | undefined;

	function activate(os: string | undefined) {
		let active: HTMLElement | null = null;

		for (const t of tabs) {
			t.classList.toggle("active", t.dataset.os === os);
		}

		for (const p of panels) {
			const on = p.dataset.os === os;
			p.classList.toggle("active", on);
			if (on) active = p;
		}

		if (active) wrap.style.height = active.offsetHeight + "px";
		window.clearTimeout(copiedTimer);
		copyIcon.innerHTML = normalIcon;
	}

	async function copyActivePanel() {
		const active = document.querySelector<HTMLElement>(
			"#install .panel.active",
		);
		const code = active?.textContent?.trim();

		if (!code) return;

		try {
			await navigator.clipboard.writeText(code);

			copyIcon.innerHTML = copiedIcon;
			copy.setAttribute("aria-label", "Copied install command");

			window.clearTimeout(copiedTimer);
			copiedTimer = window.setTimeout(() => {
				copyIcon.innerHTML = normalIcon;
				copy.setAttribute("aria-label", "Copy install command");
			}, 2000);
		} catch {
			copy.setAttribute("aria-label", "Could not copy");
		}
	}

	for (const tab of tabs) {
		tab.addEventListener("click", () => activate(tab.dataset.os));
	}

	copy.addEventListener("click", copyActivePanel);

	activate("mac");

	window.addEventListener("resize", () => {
		const cur = document.querySelector<HTMLElement>("#install .panel.active");
		if (cur) wrap.style.height = cur.offsetHeight + "px";
	});
</script>
